# Canonical local admin dev mode:
# - admin portal: http://127.0.0.1:20101
# - backend API is proxied by Vite from /api/v1 to http://127.0.0.1:21101
# - root path redirects by role to /dashboard or /workbench/active

# API 配置
VITE_API_BASE_URL=/api/v1

# WebSocket 配置
# Optional override when not using the Vite proxy:
# VITE_WS_URL=ws://127.0.0.1:21101
