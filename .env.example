# Docker Compose runtime environment for StiGPT frontent

POSTGRES_DB=game_ai_cs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-postgres-password

JWT_SECRET=replace-with-openssl-rand-base64-32
JWT_EXPIRES_IN=8h

DIFY_API_KEY=replace-with-dify-api-key
DIFY_BASE_URL=http://ai.sh7road.com/v1

ENCRYPTION_SECRET_KEY=replace-with-32-char-encryption-key
ENCRYPTION_SALT=replace-with-unique-salt

BAIDU_TRANSLATE_APP_ID=replace-with-baidu-app-id
BAIDU_TRANSLATE_SECRET=replace-with-baidu-secret

ALIYUN_API_KEY=replace-with-aliyun-api-key
ALIYUN_ACCESS_KEY_ID=replace-with-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-aliyun-access-key-secret

# Optional overrides
FRONTEND_URL=http://localhost:32111,http://localhost:32112,http://127.0.0.1:32111,http://127.0.0.1:32112
BACKEND_HOST_PORT=32101
ADMIN_HOST_PORT=32111
PLAYER_HOST_PORT=32112
POSTGRES_HOST_PORT=32113
REDIS_HOST_PORT=32114
MILVUS_GRPC_HOST_PORT=32115
MILVUS_HTTP_HOST_PORT=32116
LOG_LEVEL=INFO
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=25
LLM_MODEL=qwen-turbo
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7
TTS_VOICE=zhixiaoxia
TTS_SAMPLE_RATE=16000
TTS_FORMAT=wav
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_DOCUMENT_SIZE=52428800
SUPPORTED_DOCUMENT_TYPES=pdf,md
